@model IEnumerable<SecureShopDemo.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
}

<h2 class="mb-4">📋 Audit Logs — Nhật ký hành động</h2>

<a href="/Security/Dashboard" class="btn btn-outline-secondary mb-3">← Về Dashboard</a>

@if (!Model.Any()) {
    <div class="alert alert-info">Chưa có Audit Log nào.</div>
} else {
    <table class="table table-bordered table-striped table-sm">
        <thead class="table-dark">
            <tr>
                <th>Thời gian</th>
                <th>Username</th>
                <th>Hành động</th>
                <th>Đối tượng</th>
                <th>Mô tả</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model) {
                <tr>
                    <td>@log.CreatedAt.ToString("HH:mm:ss dd/MM/yyyy")</td>
                    <td><strong>@log.Username</strong></td>
                    <td><span class="badge bg-primary">@log.Action</span></td>
                    <td>@log.EntityType</td>
                    <td class="text-muted">@log.Description</td>
                    <td>@log.IpAddress</td>
                </tr>
            }
        </tbody>
    </table>
}