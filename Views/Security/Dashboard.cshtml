@model IEnumerable<SecureShopDemo.Models.LoginAttemptLog>

@{
    ViewData["Title"] = "Security Dashboard";
}

<h2 class="mb-4">🛡️ Security Dashboard</h2>

<div class="row mb-3">
    <div class="col-md-3">
        <div class="card bg-info text-white"><div class="card-body"><h6>📊 Tổng đăng nhập</h6><h3>@ViewBag.TotalLogin</h3></div></div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white"><div class="card-body"><h6>✅ Đăng nhập thành công</h6><h3>@ViewBag.SuccessLogin</h3></div></div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white"><div class="card-body"><h6>❌ Đăng nhập thất bại</h6><h3>@ViewBag.FailLogin</h3></div></div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark"><div class="card-body"><h6>⚠️ Sự kiện tấn công</h6><h3>@ViewBag.TotalAttacks</h3></div></div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-dark text-white"><div class="card-body"><h6>🚫 IP đang bị chặn</h6><h3>@ViewBag.BlockedIpCount</h3></div></div>
    </div>
    <div class="col-md-3">
        <div class="card bg-secondary text-white"><div class="card-body"><h6>📁 Tổng file upload</h6><h3>@ViewBag.TotalUploads</h3></div></div>
    </div>
    <div class="col-md-3">
        <div class="card" style="background-color:#dc3545;color:white"><div class="card-body"><h6>☣️ File nguy hiểm</h6><h3>@ViewBag.UnsafeUploads</h3></div></div>
    </div>
    <div class="col-md-3">
        <div class="card" style="background-color:#6f42c1;color:white"><div class="card-body"><h6>💉 SQL Injection</h6><h3>@ViewBag.SqlInjectionCount</h3></div></div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card" style="background-color:#fd7e14;color:white"><div class="card-body"><h6>🌊 DDoS Suspected</h6><h3>@ViewBag.DdosCount</h3></div></div>
    </div>
    <div class="col-md-3">
        <div class="card" style="background-color:#20c997;color:white"><div class="card-body"><h6>📋 Audit Logs</h6><h3>@ViewBag.TotalAuditLogs</h3></div></div>
    </div>
</div>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn btn-outline-primary" href="/Security/LoginLogs">📋 Lịch sử đăng nhập</a>
    <a class="btn btn-outline-danger" href="/Security/AttackLogs">💥 Nhật ký tấn công</a>
    <a class="btn btn-outline-dark" href="/Security/BlockedIps">🚫 IP đang bị chặn</a>
    <a class="btn btn-outline-info" href="/FileSecurity/UploadLogs">📁 Nhật ký upload</a>
    <a class="btn btn-outline-success" href="/Security/AuditLogs">📋 Audit Logs</a>
    <a class="btn btn-outline-warning" href="/Security/Lab">🧪 Security Lab</a>
</div>

<h4>📅 10 lần đăng nhập gần nhất</h4>
<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr><th>Username</th><th>IP</th><th>Trạng thái</th><th>Thời gian</th><th>Ghi chú</th></tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.Username</td>
                <td>@log.IpAddress</td>
                <td>
                    @if (log.IsSuccess)
                    { <span class="badge bg-success">✅ Success</span> }
                    else
                    { <span class="badge bg-danger">❌ Fail</span> }
                </td>
                <td>@log.AttemptTime.ToString("HH:mm:ss dd/MM/yyyy")</td>
                <td>@log.Note</td>
            </tr>
        }
    </tbody>
</table>