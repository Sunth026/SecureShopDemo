@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Trang chủ";
    var username = Context.Session.GetString("Username");
    var fullName = Context.Session.GetString("FullName");
    var role = Context.Session.GetString("Role");
    var isAdmin = role == "Admin";
    var isLoggedIn = !string.IsNullOrEmpty(username);
}

<style>
    .home-page {
        padding: 20px 0 40px;
    }

    .hero-section {
        background: linear-gradient(135deg, #0f172a, #1e3a8a, #2563eb);
        color: #fff;
        border-radius: 24px;
        padding: 48px 40px;
        margin-bottom: 28px;
        box-shadow: 0 18px 40px rgba(37, 99, 235, 0.18);
        position: relative;
        overflow: hidden;
    }

        .hero-section::before {
            content: "";
            position: absolute;
            top: -70px;
            right: -70px;
            width: 220px;
            height: 220px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }

        .hero-section::after {
            content: "";
            position: absolute;
            bottom: -90px;
            left: -60px;
            width: 210px;
            height: 210px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.14);
        color: #eaf2ff;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 16px;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 14px;
    }

    .hero-desc {
        font-size: 1.05rem;
        color: rgba(255,255,255,0.9);
        max-width: 760px;
        margin-bottom: 24px;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        background: #ffffff;
        color: #1d4ed8;
        border: none;
        font-weight: 700;
        border-radius: 12px;
        padding: 12px 20px;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .btn-hero-primary:hover {
            color: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12);
        }

    .btn-hero-outline {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.35);
        font-weight: 700;
        border-radius: 12px;
        padding: 12px 20px;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .btn-hero-outline:hover {
            color: #fff;
            background: rgba(255,255,255,0.08);
        }

    .status-card {
        background: #fff;
        border: 1px solid #e8eef6;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
        margin-bottom: 24px;
    }

    .status-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 12px;
    }

    .status-box-success,
    .status-box-warning {
        border-radius: 14px;
        padding: 16px 18px;
        margin-bottom: 18px;
        font-size: 1rem;
    }

    .status-box-success {
        background: #ecfdf5;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .status-box-warning {
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
    }

    .badge-role-admin {
        background: #dc2626;
        color: #fff;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 0.8rem;
        font-weight: 700;
        margin-left: 10px;
    }

    .action-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

        .action-buttons .btn {
            border-radius: 12px;
            padding: 11px 18px;
            font-weight: 600;
        }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 12px;
    }

    .feature-card {
        background: #fff;
        border: 1px solid #e8eef6;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
        transition: all 0.2s ease;
        height: 100%;
    }

        .feature-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08);
        }

    .feature-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 16px;
    }

    .icon-blue {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .icon-green {
        background: #dcfce7;
        color: #15803d;
    }

    .icon-red {
        background: #fee2e2;
        color: #dc2626;
    }

    .feature-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 10px;
    }

    .feature-desc {
        color: #6b7280;
        margin-bottom: 0;
        line-height: 1.6;
    }

    @@media (max-width: 992px) {
        .feature-grid {
            grid-template-columns: 1fr;
        }

        .hero-title {
            font-size: 2rem;
        }
    }

    @@media (max-width: 768px) {
        .hero-section {
            padding: 32px 24px;
        }

        .hero-title {
            font-size: 1.7rem;
        }

        .hero-desc {
            font-size: 0.98rem;
        }
    }
</style>

<div class="container home-page">
    <div class="hero-section">
        <div class="hero-content">
         
            <h1 class="hero-title">Mô phỏng bán hàng an toàn với các cơ chế bảo mật thực tế</h1>
            <p class="hero-desc">
                Hệ thống hỗ trợ đăng nhập, xem sản phẩm, đặt hàng và mô phỏng các chức năng bảo mật
                như kiểm soát truy cập, giám sát hành vi và khu quản trị dành riêng cho admin.
            </p>

            <div class="hero-actions">
                @if (isLoggedIn)
                {
                    <a class="btn-hero-primary" href="/Product">Vào khu sản phẩm</a>
                    <a class="btn-hero-outline" href="/Order/CsrfDemo">Đặt hàng</a>

                    @if (isAdmin)
                    {
                        <a class="btn-hero-outline" href="/Security/Dashboard">Quản trị bảo mật</a>
                    }
                }
                else
                {
                    <a class="btn-hero-primary" href="/Account/Login">Đăng nhập ngay</a>
                    <a class="btn-hero-outline" href="/Account/Register">Tạo tài khoản</a>
                }
            </div>
        </div>
    </div>

    <div class="status-card">
        <div class="status-title">Trạng thái truy cập</div>

        @if (isLoggedIn)
        {
            <div class="status-box-success">
                Bạn đang đăng nhập với tài khoản:
                <b>@fullName (@username)</b>
                @if (isAdmin)
                {
                    <span class="badge-role-admin">Admin</span>
                }
            </div>

            <div class="action-buttons">
                <a class="btn btn-primary" href="/Product">Vào khu sản phẩm</a>
                <a class="btn btn-outline-secondary" href="/Order/CsrfDemo">Đặt hàng</a>

                @if (isAdmin)
                {
                    <a class="btn btn-outline-dark" href="/Security/Dashboard">Quản trị bảo mật</a>
                    <a class="btn btn-outline-warning" href="/Security/Lab">Security Lab</a>
                    <a class="btn btn-outline-info" href="/FileSecurity/UploadDemo">Upload file</a>
                }
            </div>
        }
        else
        {
            <div class="status-box-warning">
                Bạn chưa đăng nhập. Vui lòng đăng nhập hoặc đăng ký trước khi truy cập hệ thống.
            </div>

           
        }
    </div>

    <div class="feature-grid">
        <div class="feature-card">
            <div class="feature-icon icon-blue">🛒</div>
            <div class="feature-title">Khu sản phẩm</div>
            <p class="feature-desc">
                Người dùng có thể xem danh sách sản phẩm, tìm kiếm, xem chi tiết và thao tác giống một website bán hàng thực tế.
            </p>
        </div>

        <div class="feature-card">
            <div class="feature-icon icon-green">📦</div>
            <div class="feature-title">Đặt hàng & tương tác</div>
            <p class="feature-desc">
                Hệ thống hỗ trợ quy trình đặt hàng và làm nền để tích hợp bình luận, đính kèm file sau khi mua hàng thành công.
            </p>
        </div>

        <div class="feature-card">
            <div class="feature-icon icon-red">🛡️</div>
            <div class="feature-title">Giám sát bảo mật</div>
            <p class="feature-desc">
                Admin có thể truy cập khu quản trị để theo dõi các chức năng bảo mật, nhật ký hệ thống và các mô phỏng tấn công.
            </p>
        </div>
    </div>
</div>