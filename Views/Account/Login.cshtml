@model SecureShopDemo.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    .login-page {
        min-height: calc(100vh - 180px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 0 50px;
    }

    .login-wrapper {
        width: 100%;
        max-width: 1100px;
    }

    .login-card {
        background: #fff;
        border: 1px solid #e8eef6;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
    }

    .login-left {
        background: linear-gradient(135deg, #0f172a, #1d4ed8, #2563eb);
        color: #fff;
        padding: 48px 36px;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .login-left::before {
            content: "";
            position: absolute;
            top: -60px;
            right: -60px;
            width: 180px;
            height: 180px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }

        .login-left::after {
            content: "";
            position: absolute;
            bottom: -70px;
            left: -50px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

    .login-left-content {
        position: relative;
        z-index: 2;
    }

    .login-badge {
        display: inline-block;
        background: rgba(255,255,255,0.14);
        color: #eaf2ff;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 18px;
    }

    .login-left-title {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1.25;
        margin-bottom: 14px;
    }

    .login-left-desc {
        font-size: 1rem;
        color: rgba(255,255,255,0.92);
        line-height: 1.7;
        margin-bottom: 28px;
    }

    .login-feature-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .login-feature-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 0.98rem;
        color: rgba(255,255,255,0.95);
    }

    .login-feature-icon {
        width: 30px;
        height: 30px;
        flex-shrink: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        margin-top: 2px;
    }

    .login-right {
        padding: 42px 36px;
        background: #fff;
    }

    .login-form-title {
        font-size: 2rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
    }

    .login-form-subtitle {
        color: #6b7280;
        margin-bottom: 24px;
    }

    .success-box {
        background: #ecfdf5;
        border: 1px solid #bbf7d0;
        color: #166534;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 18px;
        font-weight: 500;
    }

    .validation-box {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 18px;
    }

    .form-label {
        font-weight: 700;
        color: #374151;
        margin-bottom: 8px;
    }

    .form-control {
        height: 52px;
        border-radius: 14px;
        border: 1px solid #d6deea;
        box-shadow: none !important;
        padding: 12px 16px;
        font-size: 1rem;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.12) !important;
        }

    .btn-login {
        height: 50px;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        background: linear-gradient(135deg, #1d4ed8, #2563eb);
    }

        .btn-login:hover {
            opacity: 0.96;
        }

    .btn-register {
        height: 50px;
        border-radius: 14px;
        font-weight: 700;
    }

    .login-footer-note {
        margin-top: 18px;
        color: #6b7280;
        font-size: 0.95rem;
    }

        .login-footer-note a {
            color: #2563eb;
            text-decoration: none;
            font-weight: 600;
        }

    .field-validation-error {
        display: block;
        margin-top: 6px;
        font-size: 0.9rem;
    }

    @@media (max-width: 991px) {
        .login-left {
            padding: 32px 24px;
        }

        .login-right {
            padding: 32px 24px;
        }

        .login-left-title,
        .login-form-title {
            font-size: 1.7rem;
        }
    }
</style>

<div class="container login-page">
    <div class="login-wrapper">
        <div class="login-card">
            <div class="row g-0">
                <div class="col-lg-6">
                    <div class="login-left">
                        <div class="login-left-content">
                            <div class="login-badge">Khu vực đăng nhập</div>
                            <h1 class="login-left-title">Đăng nhập để truy cập hệ thống bán hàng an toàn</h1>
                            <p class="login-left-desc">
                                Hệ thống hỗ trợ xác thực người dùng, phân quyền theo vai trò và mô phỏng
                                các cơ chế bảo mật để phục vụ demo đề tài an toàn thông tin.
                            </p>

                            <div class="login-feature-list">
                                <div class="login-feature-item">
                                    <div class="login-feature-icon">✓</div>
                                    <div>Truy cập khu sản phẩm, giỏ hàng và đặt hàng.</div>
                                </div>
                                <div class="login-feature-item">
                                    <div class="login-feature-icon">✓</div>
                                    <div>Admin có thể vào Security Dashboard và Security Lab.</div>
                                </div>
                                <div class="login-feature-item">
                                    <div class="login-feature-icon">✓</div>
                                    <div>Mật khẩu được mã hóa, đăng nhập được ghi log để theo dõi bảo mật.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="login-right">
                        <h2 class="login-form-title">Đăng nhập</h2>
                        <p class="login-form-subtitle">Nhập thông tin tài khoản để tiếp tục.</p>

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="success-box">@TempData["SuccessMessage"]</div>
                        }

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="validation-box"></div>
                        }

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label asp-for="Username" class="form-label">Tên đăng nhập</label>
                                <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập" />
                                <span asp-validation-for="Username" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Mật khẩu</label>
                                <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-primary btn-login">Đăng nhập</button>
                                <a asp-action="Register" class="btn btn-outline-secondary btn-register">Tạo tài khoản mới</a>
                            </div>
                        </form>

                        <div class="login-footer-note">
                            Chưa có tài khoản?
                            <a asp-action="Register">Đăng ký ngay</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}